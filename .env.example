# PostgreSQL (docker-compose and app)
POSTGRES_USER=resonate
POSTGRES_PASSWORD=resonate
POSTGRES_DB=resonate
POSTGRES_PORT=5432

# Drizzle (CLI and SvelteKit app). Match docker-compose or your local DB.
DATABASE_URL=postgresql://resonate:resonate@localhost:5432/resonate

# Better Auth — https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET= # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:5173

# Demo sign-in: one synthetic email/password per dataset user (server-only, never sent to the browser)
RESONATE_IMPERSONATE_PASSWORD= # min 8 characters

# Last.fm API — artist images (https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# Wikipedia API — optional; server uses a default if unset. Wikimedia wants a descriptive UA:
# https://meta.wikimedia.org/wiki/User-Agent_policy
# WIKIPEDIA_USER_AGENT=MyApp/1.0 (https://example.com/; contact@example.com)
